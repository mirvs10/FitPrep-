# Variables de Entorno - Backend Spring Boot

# Base de Datos (Si usas Supabase, Render o AWS, reemplaza estos valores)
DB_URL=jdbc:postgresql://localhost:5432/Fitprep
DB_USERNAME=postgres
DB_PASSWORD=root

# Seguridad JWT (Genera una cadena larga y segura en produccion)
# Ejemplo: jwt.secret=MiClaveSuperSecretaParaProduccion2026!
jwt.secret=FitprepSuperSecretKeyForJWTAuthThatMustBeLongAndSecure
